<Window x:Class="CCXboxController.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Claude Code · Xbox Controller Companion"
        Height="720" Width="1020"
        WindowStartupLocation="CenterScreen"
        Icon="app.ico"
        Background="{StaticResource BgBrush}">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top status bar -->
        <Border Grid.Row="0" Background="{StaticResource PanelBrush}" Padding="12" CornerRadius="6" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <Ellipse x:Name="ConnDot" Width="12" Height="12" Fill="#FFB94A4A" VerticalAlignment="Center"/>
                <TextBlock x:Name="ConnText" Text="Kontrolcü bağlı değil" Margin="8,0,16,0" VerticalAlignment="Center"/>
                <TextBlock Text="·" Foreground="{StaticResource MutedBrush}" Margin="0,0,16,0" VerticalAlignment="Center"/>
                <TextBlock Text="Son tetiklenen:" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                <TextBlock x:Name="LastTrigger" Text="—" Margin="8,0,0,0" Foreground="{StaticResource AccentBrush}" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Main content: list + editor -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource PanelBrush}" Padding="8" CornerRadius="6" Margin="0,0,8,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="TUŞLAR" Foreground="{StaticResource MutedBrush}" FontWeight="Bold" Margin="4,4,0,8"/>
                    <ListBox x:Name="BindingList" SelectionChanged="BindingList_SelectionChanged" BorderThickness="0"/>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Background="{StaticResource PanelBrush}" Padding="16" CornerRadius="6">
                <Grid x:Name="EditorPanel">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="SelectedKeyLabel" Text="Seçim yok" FontSize="20" FontWeight="Bold" Margin="0,0,0,12"/>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="Aksiyon tipi:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox x:Name="ActionTypeBox" Width="220" SelectionChanged="ActionTypeBox_SelectionChanged">
                            <ComboBoxItem Content="Metin yaz"/>
                            <ComboBoxItem Content="Sesli yazım (push-to-talk)"/>
                        </ComboBox>
                    </StackPanel>
                    <TextBlock x:Name="TextLabel" Grid.Row="2" Text="Yazılacak metin (\n = Enter)" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
                    <TextBox x:Name="TextBoxValue" Grid.Row="3" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" TextChanged="TextBoxValue_TextChanged"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Bottom settings panel -->
        <Border Grid.Row="2" Background="{StaticResource PanelBrush}" Padding="12" CornerRadius="6" Margin="0,10,0,0">
            <StackPanel>
                <!-- Row 1: general -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <CheckBox x:Name="AutostartBox" Content="Windows ile birlikte başlat" VerticalAlignment="Center" Checked="AutostartBox_Toggle" Unchecked="AutostartBox_Toggle"/>
                        <TextBlock Text="·" Foreground="{StaticResource MutedBrush}" Margin="16,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Dil:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox x:Name="LangBox" Width="90" SelectionChanged="LangBox_SelectionChanged">
                            <ComboBoxItem Content="tr"/>
                            <ComboBoxItem Content="auto"/>
                            <ComboBoxItem Content="en"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="Overlay'i kapat" Click="CloseOverlay_Click"/>
                    </StackPanel>
                </Grid>

                <Separator Background="#FF3F3F46" Margin="0,4,0,8"/>

                <!-- Row 2: STT provider -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="Ses-metin sağlayıcı:" VerticalAlignment="Center" Margin="0,0,12,0" FontWeight="Bold"/>
                    <RadioButton x:Name="LocalRadio" Content="Yerel (Whisper)" GroupName="STT" VerticalAlignment="Center" Checked="ProviderChanged" Margin="0,0,16,0"/>
                    <RadioButton x:Name="OpenAiRadio" Content="OpenAI API (online)" GroupName="STT" VerticalAlignment="Center" Checked="ProviderChanged"/>
                </StackPanel>

                <!-- Local provider details -->
                <StackPanel x:Name="LocalPanel" Orientation="Horizontal" Margin="0,0,0,0">
                    <TextBlock Text="Yerel model:" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock x:Name="ModelStatus" Text="bilinmiyor" VerticalAlignment="Center"/>
                    <Button x:Name="DownloadButton" Content="Modeli indir (~466 MB)" Margin="12,0,0,0" Click="DownloadButton_Click"/>
                    <Button x:Name="CalibrateButton" Content="Ses Kalibrasyonu" Margin="8,0,0,0" Click="CalibrateButton_Click"/>
                    <TextBlock Text="Initial prompt:" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="16,0,6,0"/>
                    <TextBlock x:Name="InitialPromptPreview" Text="—" VerticalAlignment="Center" MaxWidth="280" TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <!-- OpenAI provider details -->
                <Grid x:Name="OpenAiPanel" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="API key:" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <PasswordBox x:Name="ApiKeyBox" Grid.Column="1" Background="#FF1E1E1E" Foreground="{StaticResource TextBrush}" BorderBrush="#FF3F3F46" Padding="6,4" PasswordChanged="ApiKeyBox_Changed"/>
                    <TextBlock Grid.Column="2" Text="Model:" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="16,0,8,0"/>
                    <ComboBox x:Name="OpenAiModelBox" Grid.Column="3" Width="210" SelectionChanged="OpenAiModelBox_Changed">
                        <ComboBoxItem Content="gpt-4o-transcribe"/>
                        <ComboBoxItem Content="gpt-4o-mini-transcribe"/>
                        <ComboBoxItem Content="whisper-1"/>
                    </ComboBox>
                    <Button Grid.Column="4" Content="Bağlantıyı test et" Margin="12,0,0,0" Click="TestOpenAi_Click"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Window>
