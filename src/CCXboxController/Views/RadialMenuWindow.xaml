<Window x:Class="CCXboxController.Views.RadialMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        Focusable="False"
        IsHitTestVisible="False"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual">
    <Grid Width="280" Height="280">
        <Ellipse Width="260" Height="260" Fill="#CC1E1E1E" Stroke="#FF3A3A3A" StrokeThickness="2"/>
        <!-- Slice highlight rings (one shown at a time) -->
        <Ellipse x:Name="HighlightUp"    Width="260" Height="260" Stroke="#FF4FC3F7" StrokeThickness="6" Visibility="Collapsed"
                 StrokeDashArray="1,4" StrokeDashOffset="0"/>
        <!-- Slice labels -->
        <TextBlock x:Name="LblUp"    Text="" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Top"    Margin="0,28,0,0" FontSize="14" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="220"/>
        <TextBlock x:Name="LblDown"  Text="" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,28" FontSize="14" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="220"/>
        <TextBlock x:Name="LblLeft"  Text="" Foreground="White" HorizontalAlignment="Left"   VerticalAlignment="Center" Margin="22,0,0,0" FontSize="14" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="100"/>
        <TextBlock x:Name="LblRight" Text="" Foreground="White" HorizontalAlignment="Right"  VerticalAlignment="Center" Margin="0,0,22,0" FontSize="14" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="100"/>
        <!-- Center indicator -->
        <Border x:Name="ActiveBox" Width="120" Height="40" Background="#FF2D2D30" CornerRadius="6" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock x:Name="LblStick" Text="" Foreground="#FF4FC3F7" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontSize="13"/>
        </Border>
    </Grid>
</Window>
