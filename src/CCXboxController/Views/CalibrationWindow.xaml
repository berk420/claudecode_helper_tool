<Window x:Class="CCXboxController.Views.CalibrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ses Kalibrasyonu · Initial Prompt"
        Height="620" Width="760"
        WindowStartupLocation="CenterOwner"
        Icon="/app.ico"
        Background="{StaticResource BgBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Aşağıdaki paragrafı normal konuşma hızında ve net şekilde oku."
                   FontSize="14" FontWeight="Bold" Margin="0,0,0,4"/>
        <TextBlock Grid.Row="1" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,0,0,10"
                   Text="Transkript geldikten sonra metni dilediğin gibi düzenleyebilirsin. 'Kaydet' dediğinde alttaki metin Whisper'a initial prompt olarak verilecek — bu sayede sık kullandığın teknik kelimeler model tarafından tanınır."/>

        <Border Grid.Row="2" Background="{StaticResource PanelBrush}" CornerRadius="6" Padding="12" Margin="0,0,0,10">
            <TextBlock x:Name="ReferenceText" TextWrapping="Wrap" FontSize="13" LineHeight="20"/>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,8">
            <Button x:Name="RecordButton" Content="● Kayıt Başlat" Width="160" Click="RecordButton_Click"/>
            <TextBlock x:Name="StatusText" Text="Hazır" Margin="14,0,0,0" VerticalAlignment="Center"
                       Foreground="{StaticResource MutedBrush}"/>
        </StackPanel>

        <Grid Grid.Row="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="Transkript (düzenlenebilir — bu metin initial prompt olarak kaydedilir):"
                       Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
            <TextBox x:Name="TranscriptBox" Grid.Row="1" AcceptsReturn="True" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"/>
        </Grid>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Referans metni kullan" Width="170" Margin="0,0,8,0" Click="UseReference_Click"/>
            <Button Content="İptal" Width="90" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button x:Name="SaveButton" Content="Initial Prompt olarak kaydet" Width="220" Click="Save_Click"
                    Background="#FF0E639C"/>
        </StackPanel>
    </Grid>
</Window>
